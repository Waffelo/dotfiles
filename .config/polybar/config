;ramp-coreload-3 = Ō¢ä
;ramp-coreload-4 = Ō¢ģ
;ramp-coreload-5 = Ō¢å
;ramp-coreload-6 = Ō¢ć
;ramp-coreload-7 = Ō¢ł
;
