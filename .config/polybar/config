;------------;
;   Colors   ;=========================================================================================
;------------;

[colors]
background = #211d24
foreground = #afacbb
primary = #ffb2a
secondary = #e60053

normal = ${colors.green1}
alert = ${colors.yellow1}
critical = ${colors.red1}

; 1=darker, 2=lighter.

red1 = #a03e3e
red2 = #b64a4a

green1 = #878e42
green2 = #929852

yellow1 = #bb7749
yellow2 = #b59555

blue1 = #5c7c96
blue2 = #6688a4

magenta1 = #8c6a98
magenta2 = #94779d

cyan1 = #388177
cyan2 = #59948c

white1 = #3a3043
white2 = #484452

black1 = #2A2B2E
black2 = #43454A

;------------;
;    Bar     ;=========================================================================================
;------------;


[bar/example]
width = 100%
height = 25
radius = 0.0
fixed-center = true

enable-ipc=true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0
line-color = #f00

border-size = 0
border-color = #173C4E

padding-left = 0
padding-right = 2

module-margin-left = 1
module-margin-right = 2

tray-position = right
tray-detached = false

font-0 = cherry:style=Regular:pixelsize=11;2
font-1 = FiraCode Nerd Font:size=9;2
font-3 = Weather Icons:size=12;1

modules-left = bspwm cmus 
modules-center = date 
modules-right =  pulseaudio-control-input pulseaudio-control-output wifi  info-trash filesystem cpu memory dunst battery

; Avalible modules:
; spotify - shows spotify status
; date - shows date and time
; speedtest - shows network speed
; cpu - shows cpu usage
; memory - shows ram usage
; battery - shows battery status
; bspwm - shows virtual desktop buttons
; taskwarrior - Task viewer for taskwarrior-cli (broken)
; filesystem - shows disk status
; cmus - cmus status
; pulseaudio-control - audio control
; dunst - Notification control
; trash-info - shows how many files are in trash
; system-usb-dev - shows mounted usb drives

cursor-click = pointer
cursor-scroll = ns-resize

[module/system-usb-udev]
type = custom/script
exec = ~/.config/polybar/scripts/system-usb-udev.sh
tail = true
click-left = ~/.config/polybar/scripts/system-usb-udev.sh --mount &
click-right = ~/.config/polybar/scripts/system-usb-udev.sh --unmount &

[module/openweathermap-fullfeatured]
type = custom/script
exec = ~/.config/polybar/scripts/openweathermap-fullfeatured.sh
interval = 600
label-font = 3

[module/info-kernel]
type = custom/script
exec = uname -r
interval = 1024
format-background = ${colors.background}
format-foreground = ${colors.foreground}
format-prefix = "’ģ╝ "
format-prefix-font = 3
format-prefix-foreground = ${color.cyan}

[module/info-trash]
type = custom/script
exec = ~/.config/polybar/scripts/info-trash.sh
interval = 5
click-left = ~/.config/polybar/scripts/info-trash.sh --clean &
format-background = ${colors.background}
format-foreground = ${colors.foreground}
format-prefix = "’ćĖ’ŗŁ  "
format-prefix-font = 3
format-prefix-foreground = ${color.orange}

[module/wifi]
type = internal/network
interface = wlp3s0
unknown-as-up = true
interval = 3.0
tail = true

format-connected = "<ramp-signal><label-connected>"

format-connected-foreground = ${color.cyan}

#label-connected = %essid%  ’äā %downspeed:1:10%  ’äé %upspeed:1:10%
label-connected = %essid%
label-connected-background = ${colors.background}
label-connected-foreground = ${color.foreground}


format-disconnected-prefix  = "’¬® "
format-disconnected-prefix-foreground = ${colors.cyan}
format-disconnected-prefix-background = ${colors.background}
format-disconnected-foreground = ${colors.foreground}
format-disconnected-background = ${colors.background}

format-disconnected = NO WIFI

ramp-signal-0 = "’ć½ "
ramp-signal-foreground = ${color.cyan}
ramp-signal-background = ${color.shade}
ramp-signal-font = 3
format-padding = 2

;-------------;
;  Speedtest  ;=========================================================================================
;-------------;

[module/speedtest]
type = custom/script
exec-if = hash speedtest
exec = "$HOME/.config/polybar/scripts/speedtest.sh"
interval = 90
; requires speedtest-cli to be installed

;-------------;
;    bspwm    ;=========================================================================================
;-------------;

[module/bspwm]
type = internal/bspwm

label-focused = %name%
label-focused-foreground = #205068
label-focused-background = #120c0c
label-focused-underline= ${colors.primary}
label-focused-padding = 1

label-occupied = %name%
label-occupied-padding = 1
label-occupied-foreground = #949494

label-urgent = %name%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

label-empty = %name%
label-empty-padding = 1
label-empty-foreground = #949494

ws-name-0= TERM
ws-name-1= WWW
ws-name-2= IM
ws-name-3= VG
ws-name-4= MISC

; Separator in between workspaces
; label-separator = |

;------------;
;    date    ;=========================================================================================
;------------;


[module/date]
type = internal/date
interval = 0.50

date =
